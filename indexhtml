<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portfolio — Analista de Datos</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,700;9..144,900&family=Plus+Jakarta+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #f7f6f2;
      --white:     #ffffff;
      --ink:       #18181b;
      --ink-2:     #3f3f46;
      --ink-3:     #71717a;
      --border:    #e4e4e7;
      --accent:    #0f6b5c;
      --accent-lt: #e6f4f1;
      --accent-2:  #c2410c;
      --accent-2lt:#fff0eb;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(247,246,242,.93);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      padding: 0 5vw; height: 60px;
    }
    .nav-logo {
      font-family: 'Fraunces', serif; font-weight: 900; font-size: 1.1rem;
      color: var(--ink); text-decoration: none;
    }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: .82rem; font-weight: 500; letter-spacing: .06em;
      text-transform: uppercase; color: var(--ink-3); text-decoration: none;
      transition: color .18s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* HERO */
    #hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 80px 5vw 4rem; gap: 4rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-left { max-width: 560px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--accent-lt); color: var(--accent);
      font-size: .75rem; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase; padding: .35rem .9rem;
      border-radius: 100px; margin-bottom: 2rem;
      animation: fadeUp .5s ease both;
    }
    .hero-badge::before {
      content: ''; width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent); animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity:1; transform:scale(1); }
      50% { opacity:.5; transform:scale(.8); }
    }
    h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(3.2rem, 5.5vw, 5.2rem);
      font-weight: 900; line-height: 1.0;
      letter-spacing: -.03em; color: var(--ink);
      animation: fadeUp .5s .08s ease both;
    }
    h1 .line-accent { color: var(--accent); font-style: italic; }
    .hero-desc {
      font-size: 1.05rem; color: var(--ink-2);
      max-width: 440px; margin: 1.6rem 0 2.4rem; line-height: 1.75;
      animation: fadeUp .5s .16s ease both;
    }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp .5s .24s ease both; }
    .btn {
      display: inline-block; padding: .72rem 1.8rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: .88rem; font-weight: 600;
      text-decoration: none; border-radius: 6px;
      transition: all .18s; cursor: pointer; border: none;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #0a5449; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(15,107,92,.25); }
    .btn-ghost { background: var(--white); color: var(--ink); border: 1.5px solid var(--border); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    /* FOTO DE PERFIL PEQUEÑA */
    .hero-photo {
      margin-top: 2rem;
      animation: fadeUp .5s .3s ease both;
    }
    .hero-photo img {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--accent);
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    /* Hero visual card */
    .hero-visual { animation: fadeUp .5s .3s ease both; }
    .data-card {
      background: var(--white); border: 1px solid var(--border);
      border-radius: 12px; padding: 2rem;
      box-shadow: 0 4px 32px rgba(0,0,0,.06);
    }
    .data-card-title {
      font-size: .72rem; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: var(--ink-3);
      margin-bottom: 1.6rem; padding-bottom: .8rem;
      border-bottom: 1px solid var(--border);
    }
    .stack-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: .75rem 0; border-bottom: 1px solid var(--border);
    }
    .stack-row:last-child { border-bottom: none; }
    .stack-info { display: flex; align-items: center; gap: .8rem; }
    .stack-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .stack-name { font-size: .9rem; font-weight: 600; color: var(--ink); }
    .stack-sub { font-size: .73rem; color: var(--ink-3); font-family: 'JetBrains Mono', monospace; }
    .stack-bar-wrap { width: 100px; height: 5px; background: var(--border); border-radius: 10px; overflow: hidden; }
    .stack-bar {
      height: 100%; border-radius: 10px;
      transform-origin: left;
      animation: growBar 1.2s .6s ease forwards; transform: scaleX(0);
    }
    @keyframes growBar { to { transform: scaleX(1); } }

    /* SECTIONS */
    section { padding: 6rem 5vw; }
    .section-label {
      font-size: .72rem; font-weight: 600; letter-spacing: .14em;
      text-transform: uppercase; color: var(--accent); margin-bottom: .7rem;
    }
    h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 3.5vw, 2.9rem);
      font-weight: 900; letter-spacing: -.025em; line-height: 1.1;
      color: var(--ink); margin-bottom: .8rem;
    }
    .section-sub {
      font-size: 1rem; color: var(--ink-3);
      max-width: 520px; margin-bottom: 3.5rem; line-height: 1.7;
    }

    /* SKILLS */
    #skills { background: var(--white); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.2rem; }
    .skill-card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.6rem;
      transition: transform .2s, box-shadow .2s, border-color .2s;
    }
    .skill-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.07); border-color: var(--accent); }
    .skill-icon-wrap {
      width: 42px; height: 42px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; margin-bottom: 1rem;
    }
    .skill-title { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; color: var(--ink); margin-bottom: .4rem; }
    .skill-tools { font-size: .8rem; color: var(--ink-3); line-height: 1.6; }
    .skill-level { display: flex; align-items: center; gap: .4rem; margin-top: 1rem; }
    .level-pip { width: 8px; height: 8px; border-radius: 50%; background: var(--border); }
    .level-pip.on { background: var(--accent); }

    /* PROJECTS */
    #projects { background: var(--bg); }
    .projects-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .project-card {
      background: var(--white); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      display: grid; grid-template-columns: 200px 56px 1fr auto;
      align-items: start; gap: 0;
      transition: transform .2s, box-shadow .2s, border-color .2s;
    }
    .project-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,.07); border-color: var(--accent); }
    .project-img {
      width: 200px; align-self: stretch; overflow: hidden; flex-shrink: 0;
    }
    .project-img img {
      width: 100%; height: 100%; object-fit: cover;
      display: block; transition: transform .4s ease;
    }
    .project-card:hover .project-img img { transform: scale(1.04); }
    .project-inner {
      display: grid; grid-template-columns: 56px 1fr auto;
      align-items: start; gap: 1.8rem; padding: 2rem 2.2rem;
      grid-column: 2 / -1;
    }
    .project-num {
      font-family: 'Fraunces', serif; font-size: 2.4rem; font-weight: 900;
      color: var(--border); line-height: 1; letter-spacing: -.03em; padding-top: .2rem;
    }
    .project-title { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 700; color: var(--ink); margin-bottom: .45rem; line-height: 1.2; }
    .project-desc { font-size: .92rem; color: var(--ink-2); line-height: 1.7; margin-bottom: 1rem; }
    .tags { display: flex; flex-wrap: wrap; gap: .45rem; }
    .tag { font-size: .7rem; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; padding: .22rem .65rem; border-radius: 4px; }
    .tag-green { background: var(--accent-lt); color: var(--accent); }
    .tag-orange { background: var(--accent-2lt); color: var(--accent-2); }
    .tag-yellow { background: #fef9c3; color: #92400e; }
    .project-links { display: flex; flex-direction: column; gap: .7rem; align-items: flex-end; padding-top: .3rem; white-space: nowrap; }
    .project-link {
      font-size: .78rem; font-weight: 600; color: var(--ink-3);
      text-decoration: none; display: flex; align-items: center; gap: .3rem; transition: color .18s;
    }
    .project-link:hover { color: var(--accent); }
    .project-link svg { width: 14px; height: 14px; }

    /* ABOUT */
    #about { background: var(--white); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .about-layout { display: grid; grid-template-columns: 1.1fr 1fr; gap: 5rem; align-items: start; }
    .about-photo-wrap {
      margin-bottom: 2rem;
    }
    .about-photo-wrap img {
      width: 88px; height: 88px; border-radius: 50%;
      object-fit: cover; border: 3px solid var(--accent);
      box-shadow: 0 4px 20px rgba(15,107,92,.18);
      display: block;
    }
    .about-photo-placeholder {
      width: 88px; height: 88px; border-radius: 50%;
      background: var(--accent-lt); border: 3px solid var(--accent);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 900;
      color: var(--accent); letter-spacing: -.02em;
    }
    .about-text h2 { margin-bottom: 1.4rem; }
    .about-text p { font-size: .97rem; color: var(--ink-2); line-height: 1.8; margin-bottom: 1.1rem; }
    .about-text strong { color: var(--ink); font-weight: 600; }
    .edu-block { margin-top: 2rem; display: flex; flex-direction: column; gap: .8rem; }
    .edu-item {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1.1rem 1.2rem; background: var(--bg);
      border: 1px solid var(--border); border-radius: 8px;
    }
    .edu-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); margin-top: .35rem; flex-shrink: 0; }
    .edu-title { font-size: .93rem; font-weight: 600; color: var(--ink); }
    .edu-sub { font-size: .8rem; color: var(--ink-3); margin-top: .15rem; }
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .stat-box { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 1.6rem; }
    .stat-num { font-family: 'Fraunces', serif; font-size: 2.6rem; font-weight: 900; color: var(--accent); line-height: 1; letter-spacing: -.03em; }
    .stat-label { font-size: .78rem; font-weight: 500; color: var(--ink-3); margin-top: .4rem; line-height: 1.4; }

    /* CONTACT */
    #contact { background: var(--bg); }
    .contact-inner { max-width: 600px; }
    .contact-inner .section-sub { margin-bottom: 2.5rem; }
    .contact-row {
      display: flex; align-items: center; gap: 1rem;
      padding: 1.1rem 1.4rem; background: var(--white);
      border: 1px solid var(--border); border-radius: 8px;
      margin-bottom: .7rem; text-decoration: none; color: var(--ink);
      transition: border-color .18s, transform .18s, box-shadow .18s;
    }
    .contact-row:hover { border-color: var(--accent); transform: translateX(4px); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .contact-icon {
      width: 38px; height: 38px; border-radius: 8px;
      background: var(--accent-lt); color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .contact-label { font-size: .93rem; font-weight: 600; }
    .contact-val { font-size: .82rem; color: var(--ink-3); font-family: 'JetBrains Mono', monospace; }
    .contact-arrow { margin-left: auto; color: var(--ink-3); font-size: 1rem; transition: transform .18s, color .18s; }
    .contact-row:hover .contact-arrow { transform: translateX(3px); color: var(--accent); }

    /* FOOTER */
    footer {
      padding: 1.8rem 5vw; border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      font-size: .8rem; color: var(--ink-3);
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .reveal { opacity: 1; transform: translateY(0); transition: opacity .6s ease, transform .6s ease; }
    .js-ready .reveal { opacity: 0; transform: translateY(22px); }
    .js-ready .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    @media (max-width: 860px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; }
      #hero { grid-template-columns: 1fr; padding: 80px 1.5rem 3rem; }
      .hero-visual { display: none; }
      section { padding: 4rem 1.5rem; }
      .project-card { grid-template-columns: 1fr; }
      .project-img { width: 100%; height: 160px; }
      .project-inner { grid-column: 1; grid-template-columns: 1fr; gap: 1rem; padding: 1.4rem; }
      .project-num { display: none; }
      .project-links { flex-direction: row; align-items: flex-start; }
      .about-layout { grid-template-columns: 1fr; gap: 3rem; }
      footer { flex-direction: column; gap: .5rem; text-align: center; }
    }
  </style>
</head>
